rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['isPro', 'purchaseDate', 'digistore24OrderId', 'digistore24Email', 'payMethod', 'examDate', 'examDateCode', 'proExpiredAt']);
      allow delete: if false;
    }

    // User subcollections
    match /users/{userId}/progress/{date} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/freetextChallenges/{date} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if false; // Only Cloud Function can write
    }

    // Voucher codes — Cloud Functions only
    match /vouchers/{code} {
      allow read, write: if false;
    }

    // Leaderboard — Pro-User dürfen lesen, nur Cloud Functions schreiben
    match /leaderboard/{yearMonth}/entries/{uid} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPro == true;
      allow write: if false;
    }
  }
}